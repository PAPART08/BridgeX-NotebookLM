{
"update_url": "https://clients2.google.com/service/update2/crx",

  "manifest_version": 3,
  "name": "Decodr - NotebookLM Power Toolkit",
  "version": "1.1.2",
  "description": "The ultimate power toolkit for NotebookLM - folders, tags, imports, exports, and more",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "identity",
    "contextMenus",
    "alarms",
    "notifications",
    "sidePanel",
    "scripting",
    "activeTab"
  ],
  "oauth2": {
    "client_id": "1006584017183-71ggq2dbejpvokc0hq2s50c2npssjvis.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/userinfo.profile"
    ]
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "host_permissions": [
    "https://notebooklm.google.com/*",
    "https://lh3.googleusercontent.com/*",
    "https://lh3.google.com/*",
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://www.youtube.com/*",
    "https://checkout.paystack.com/*"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "js": [
        "assets/index.tsx-loader-tHaGtCxC.js"
      ],
      "matches": [
        "https://notebooklm.google.com/*"
      ],
      "run_at": "document_end",
      "css": [
        "assets/index-CBRnYqu-.css"
      ]
    },
    {
      "js": [
        "assets/index.tsx-loader-DYjbEkCh.js"
      ],
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*"
      ],
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/index.tsx-loader-DJGOT9vb.js"
      ],
      "matches": [
        "https://claude.ai/*"
      ],
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/index.tsx-loader-B3LA6O0H.js"
      ],
      "matches": [
        "https://gemini.google.com/*"
      ],
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/index.tsx-loader-CGGd6Y9c.js"
      ],
      "matches": [
        "https://www.youtube.com/*"
      ],
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/index.ts-BMQ3KMvo.js"
      ],
      "matches": [
        "https://checkout.paystack.com/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "icons/*",
        "assets/*",
        "sql-wasm.wasm",
        "pdf.worker.min.js"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "https://notebooklm.google.com/*"
